# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
POSTGRES_USER=ric_user
POSTGRES_PASSWORD=ric_dev_password_change_in_prod
POSTGRES_DB=ric_conductor
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://ric_user:ric_dev_password_change_in_prod@postgres:5432/ric_conductor

# ─── REDIS ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── JWT / SEGURIDAD ──────────────────────────────────────────────────────────
JWT_SECRET=dev_secret_change_me_in_prod_use_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ─── ENTORNO ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ─── SERVICIOS INTERNOS ───────────────────────────────────────────────────────
PDF_SERVICE_URL=http://pdf-service:9000
BACKEND_URL=http://backend:8000

# ─── FRONTEND (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev_nextauth_secret_change_in_prod

# ─── GOOGLE OAUTH ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── STRIPE (pendiente — configurar cuando se active monetización) ────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── IA (opcional) ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
